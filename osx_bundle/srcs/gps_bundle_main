#!/bin/bash
# GNAT Studio macOS bundle launcher.
#
# Installed as Contents/MacOS/gnatstudio (matching CFBundleExecutable in
# Info.plist). Delegates to Contents/MacOS/bin/gnatstudio, which is the
# copy of distrib/gps_wrapper that "make install-strip" lays down on
# darwin. gps_wrapper sets up DYLD_FALLBACK_LIBRARY_PATH, GI_TYPELIB_PATH,
# XDG_DATA_DIRS, etc., and execs bin/gnatstudio_exe.

set -e

DIR="$(cd "$(dirname "$0")" && pwd -P)"

# macOS passes -psn_0_nnnnn to apps launched by LaunchServices on older
# systems. Strip it so gnatstudio doesn't see it as a positional arg.
if [ $# -gt 0 ] && [[ "$1" == -psn_* ]]; then
    shift
fi

exec "$DIR/bin/gnatstudio" "$@"
